INVITE_CODE=changeme
JWT_SECRET=changeme-to-random-string
MAX_CONCURRENT_MATCHES=2
ENGINE_UPLOAD_MAX_SIZE_MB=50

# Distributed Worker Support (optional — set WORKER_SECRET to enable)
# WORKER_SECRET=your-strong-random-secret

# Worker-only env vars (set on worker VPS, not master):
# MASTER_URL=http://10.0.0.1:3000
# WORKER_ID=worker-1
